---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — Molduras Bolivia"
  description="Página no encontrada"
  transparentHeader={false}
>

  <section class="not-found">
    <p class="not-found-face">:(</p>
    <h1 class="not-found-title">Página no encontrada</h1>
    <p class="not-found-desc">La página que buscas no existe o fue movida.</p>
    <a href="/" class="not-found-link">Volver al inicio</a>
  </section>

</BaseLayout>

<style>
  .not-found {
    min-height: 70vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 24px 96px;
  }

  .not-found-face {
    font-size: 72px;
    font-weight: 700;
    color: var(--color-text-heading);
    line-height: 1;
    margin-bottom: 24px;
  }

  .not-found-title {
    font-size: 28px;
    font-weight: 700;
    color: var(--color-text-heading);
    margin-bottom: 12px;
  }

  .not-found-desc {
    font-size: 16px;
    color: var(--color-text-body);
    margin-bottom: 32px;
  }

  .not-found-link {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-orange);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }

  .not-found-link:hover {
    border-color: var(--color-orange);
  }
</style>
