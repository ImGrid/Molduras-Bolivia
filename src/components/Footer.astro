---
import logo from '../assets/logos/logo1.png';

const currentYear = new Date().getFullYear();

const links = [
  { href: '/', label: 'Inicio' },
  { href: '/catalogo', label: 'Catálogo' },
  { href: '/nosotros', label: 'Nosotros' },
  { href: '/contacto', label: 'Contacto' },
];

const whatsappNumber = '59170000000'; // TODO: reemplazar con numero real del cliente
const whatsappMessage = encodeURIComponent('Hola, me interesa cotizar un enmarcado');
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`;

// TODO: reemplazar con datos reales del cliente
const phone = '+591 7000 0000';
const address = 'Calle Ejemplo #123, Ciudad, Bolivia';
const addressMapUrl = 'https://maps.google.com/?q=Bolivia'; // TODO: link real a Google Maps
const schedule = 'Lun - Sáb: 9:00 - 18:00';
const facebookUrl = 'https://facebook.com/'; // TODO: URL real de Facebook
const instagramUrl = ''; // TODO: dejar vacio si no tiene Instagram
---

<footer class="footer">
  <div class="footer-inner">
    <!-- Columna 1: Logo + descripcion + redes -->
    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label="Ir al inicio">
        <img src={logo.src} alt="Molduras - Bolivia" width="40" height="40" />
        <span>Molduras - Bolivia</span>
      </a>
      <p class="footer-desc">
        Importación directa de marcos y molduras de calidad para cuadros, espejos, diplomas y decoración en Bolivia.
      </p>
      <div class="footer-social">
        {facebookUrl && (
          <a href={facebookUrl} target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        )}
        {instagramUrl && (
          <a href={instagramUrl} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        )}
      </div>
      <p class="footer-copyright">&copy; {currentYear} Molduras - Bolivia.</p>
    </div>

    <!-- Columna 2: Paginas -->
    <div class="footer-col">
      <h3 class="footer-heading">Páginas</h3>
      <nav aria-label="Navegación del footer">
        {links.map(link => (
          <a href={link.href} class="footer-link">{link.label}</a>
        ))}
      </nav>
    </div>

    <!-- Columna 3: Contacto -->
    <div class="footer-col">
      <h3 class="footer-heading">Contacto</h3>
      <div class="footer-contact">
        <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="footer-contact-item">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          <span>{phone}</span>
        </a>
        <a href={`tel:${phone.replace(/\s/g, '')}`} class="footer-contact-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
          <span>{phone}</span>
        </a>
        <a href={addressMapUrl} target="_blank" rel="noopener noreferrer" class="footer-contact-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>{address}</span>
        </a>
        <div class="footer-contact-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>{schedule}</span>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-charcoal);
    color: var(--color-text-on-dark);
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 48px 24px 40px;
    display: grid;
    grid-template-columns: 1.2fr 0.8fr 1fr;
    gap: 48px;
  }

  /* ===== Columna 1: Brand ===== */
  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: 16px;
  }

  .footer-logo img {
    height: 36px;
    width: auto;
  }

  .footer-logo span {
    font-size: 17px;
    font-weight: 700;
    color: white;
    letter-spacing: -0.02em;
  }

  .footer-desc {
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-text-on-dark);
    margin-bottom: 20px;
  }

  .footer-social {
    display: flex;
    gap: 12px;
  }

  .footer-social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-text-on-dark);
    transition: all 0.2s ease;
  }

  .footer-social a:hover {
    background: var(--color-orange);
    color: white;
  }

  .footer-social svg {
    width: 18px;
    height: 18px;
  }

  /* ===== Columnas 2 y 3 ===== */
  .footer-heading {
    font-size: 14px;
    font-weight: 600;
    color: white;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 20px;
  }

  .footer-col nav {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-link {
    text-decoration: none;
    color: var(--color-text-on-dark);
    font-size: 14px;
    font-weight: 400;
    transition: color 0.2s ease;
  }

  .footer-link:hover {
    color: white;
  }

  /* ===== Contacto ===== */
  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .footer-contact-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    text-decoration: none;
    color: var(--color-text-on-dark);
    font-size: 14px;
    line-height: 1.5;
    transition: color 0.2s ease;
  }

  a.footer-contact-item:hover {
    color: white;
  }

  .footer-contact-item svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* ===== Copyright ===== */
  .footer-copyright {
    font-size: 13px;
    color: var(--color-text-secondary);
    margin-top: 16px;
  }

  /* ===== Responsive ===== */
  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 36px;
      padding: 40px 24px 32px;
    }

  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 36px;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }
</style>
