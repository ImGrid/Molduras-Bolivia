---
// TODO: Reemplazar con la URL real de la página de Facebook del cliente
const facebookUrl = 'https://www.facebook.com/';
---

<section class="fb-section">
  <div class="fb-inner">
    <p class="fb-eyebrow">Síguenos</p>
    <h2 class="fb-title">Nuestras publicaciones</h2>

    <div class="fb-placeholder">
      <svg class="fb-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
      </svg>
      <p class="fb-placeholder-text">Aquí se mostrará el feed de Facebook</p>
      <p class="fb-placeholder-sub">Pendiente: URL de la página de Facebook del cliente</p>
    </div>

    <div class="fb-cta">
      <a href={facebookUrl} target="_blank" rel="noopener noreferrer">
        Seguir en Facebook
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .fb-section {
    background: var(--color-bg);
    padding: 96px 24px;
  }

  .fb-inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .fb-eyebrow {
    font-size: 12px;
    font-weight: 600;
    color: var(--color-orange);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    text-align: center;
    margin-bottom: 16px;
  }

  .fb-title {
    font-size: 36px;
    font-weight: 700;
    color: var(--color-heading);
    text-align: center;
    letter-spacing: -0.02em;
    margin-bottom: 48px;
  }

  /* Placeholder */
  .fb-placeholder {
    border: 1px dashed var(--color-border);
    border-radius: 4px;
    padding: 64px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .fb-icon {
    width: 40px;
    height: 40px;
    color: var(--color-border);
  }

  .fb-placeholder-text {
    font-size: 15px;
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .fb-placeholder-sub {
    font-size: 12px;
    color: var(--color-text-secondary);
  }

  /* CTA */
  .fb-cta {
    text-align: center;
    margin-top: 40px;
  }

  .fb-cta a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: transparent;
    color: var(--color-heading);
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.04em;
    border-radius: 2px;
    border: 1px solid var(--color-border);
    transition: border-color 0.3s ease;
  }

  .fb-cta a:hover {
    border-color: var(--color-charcoal);
  }

  .fb-cta a svg {
    width: 16px;
    height: 16px;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .fb-title { font-size: 28px; margin-bottom: 36px; }
    .fb-section { padding: 64px 24px; }
    .fb-placeholder { padding: 48px 24px; }
  }
</style>
