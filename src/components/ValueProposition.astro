---
import iconImport from '../assets/iconos/vuelo-en-avion.svg';
import iconVariety from '../assets/iconos/variedad.svg';
import iconCustom from '../assets/iconos/gobernante.svg';

const pillars = [
  {
    icon: iconImport.src,
    title: 'Importación directa',
    desc: 'Materiales traídos directamente del exterior, de fábrica a tu proyecto.',
  },
  {
    icon: iconVariety.src,
    title: 'Amplia variedad',
    desc: 'Estilos clásicos, modernos, rústicos y dorados para cada necesidad.',
  },
  {
    icon: iconCustom.src,
    title: 'Hecho a medida',
    desc: 'Enmarcado personalizado para cuadros, espejos, diplomas y decoración.',
  },
  {
    icon: null,
    title: 'Calidad garantizada',
    desc: 'Acabados profesionales con materiales de primera calidad.',
  },
];
---

<section class="value-section">
  <div class="value-inner">
    <p class="value-eyebrow">Por qué elegirnos</p>
    <h2 class="value-title">Lo que nos diferencia</h2>

    <div class="pillars">
      {pillars.map(pillar => (
        <div class="pillar">
          <div class="pillar-icon">
            {pillar.icon ? (
              <img src={pillar.icon} alt="" width="48" height="48" />
            ) : (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <path d="M5 7.2a2.2 2.2 0 0 1 2.2 -2.2h1a2.2 2.2 0 0 0 1.55 -.64l.7 -.7a2.2 2.2 0 0 1 3.12 0l.7 .7c.412 .41 .97 .64 1.55 .64h1a2.2 2.2 0 0 1 2.2 2.2v1c0 .58 .23 1.138 .64 1.55l.7 .7a2.2 2.2 0 0 1 0 3.12l-.7 .7a2.2 2.2 0 0 0 -.64 1.55v1a2.2 2.2 0 0 1 -2.2 2.2h-1a2.2 2.2 0 0 0 -1.55 .64l-.7 .7a2.2 2.2 0 0 1 -3.12 0l-.7 -.7a2.2 2.2 0 0 0 -1.55 -.64h-1a2.2 2.2 0 0 1 -2.2 -2.2v-1a2.2 2.2 0 0 0 -.64 -1.55l-.7 -.7a2.2 2.2 0 0 1 0 -3.12l.7 -.7a2.2 2.2 0 0 0 .64 -1.55v-1"/>
                <path d="M9 12l2 2l4 -4"/>
              </svg>
            )}
          </div>
          <h3 class="pillar-title">{pillar.title}</h3>
          <p class="pillar-desc">{pillar.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .value-section {
    background: var(--color-crema);
    padding: 96px 24px;
  }

  .value-inner {
    max-width: 1080px;
    margin: 0 auto;
  }

  .value-eyebrow {
    font-size: 12px;
    font-weight: 600;
    color: var(--color-orange);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    text-align: center;
    margin-bottom: 16px;
  }

  .value-title {
    font-size: 36px;
    font-weight: 700;
    color: var(--color-text-heading);
    text-align: center;
    letter-spacing: -0.02em;
    margin-bottom: 64px;
  }

  /* Grilla de 4 pilares */
  .pillars {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 48px;
  }

  .pillar {
    text-align: center;
  }

  /* Icono */
  .pillar-icon {
    width: 56px;
    height: 56px;
    margin: 0 auto 24px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pillar-icon img {
    width: 48px;
    height: 48px;
    object-fit: contain;
  }

  .pillar-icon svg {
    width: 48px;
    height: 48px;
    stroke: var(--color-charcoal);
  }

  .pillar-title {
    font-size: 17px;
    font-weight: 700;
    color: var(--color-text-heading);
    margin-bottom: 10px;
    letter-spacing: -0.01em;
  }

  .pillar-desc {
    font-size: 14px;
    color: var(--color-text-body);
    line-height: 1.65;
  }

  /* Separador vertical entre pilares */
  .pillar + .pillar {
    position: relative;
  }
  .pillar + .pillar::before {
    content: '';
    position: absolute;
    left: -24px;
    top: 10%;
    bottom: 10%;
    width: 1px;
    background: var(--color-border);
  }

  /* ===== Responsive ===== */
  @media (max-width: 900px) {
    .pillars {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px;
    }
    .pillar + .pillar::before { display: none; }
  }

  @media (max-width: 640px) {
    .pillars {
      grid-template-columns: 1fr;
      gap: 36px;
    }
    .value-title { font-size: 28px; margin-bottom: 48px; }
    .value-section { padding: 64px 24px; }
  }
</style>
