---
import logoLight from '../assets/logos/logo1.png';
import logoDark from '../assets/logos/logo3.png';

interface Props {
  transparent?: boolean;
}

const { transparent = true } = Astro.props;
const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Inicio' },
  { href: '/catalogo', label: 'Catálogo' },
  { href: '/nosotros', label: 'Nosotros' },
  { href: '/contacto', label: 'Contacto' },
];

const whatsappNumber = '59170000000'; // TODO: reemplazar con numero real del cliente
const whatsappMessage = encodeURIComponent('Hola, me interesa cotizar un enmarcado');
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`;
---

<header class:list={['header', { 'is-transparent': transparent }]} data-header>
  <div class="header-inner">
    <!-- Logo -->
    <a href="/" class="header-logo" aria-label="Ir al inicio">
      <img src={logoLight.src} alt="Molduras - Bolivia" width="42" height="42" class="logo-light" />
      <img src={logoDark.src} alt="Molduras - Bolivia" width="42" height="42" class="logo-dark" />
      <span class="header-logo-text">Molduras - Bolivia</span>
    </a>

    <!-- Nav desktop -->
    <nav class="header-nav" aria-label="Navegación principal">
      {links.map(link => (
        <a
          href={link.href}
          class:list={['header-link', { 'is-active': currentPath === link.href }]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- CTA WhatsApp (desktop) -->
    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="header-cta"
      aria-label="Contactar por WhatsApp"
    >
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      <span>WhatsApp</span>
    </a>

    <!-- Hamburger (mobile) -->
    <button
      class="header-hamburger"
      data-hamburger
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Menu mobile -->
  <nav class="header-mobile" id="mobile-menu" data-mobile-menu aria-label="Menú móvil">
    {links.map(link => (
      <a
        href={link.href}
        class:list={['header-mobile-link', { 'is-active': currentPath === link.href }]}
      >
        {link.label}
      </a>
    ))}
    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="header-mobile-cta"
    >
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      Escríbenos por WhatsApp
    </a>
  </nav>
</header>

<style>
  /* ===== HEADER BASE ===== */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: var(--color-crema);
    border-bottom: 1px solid var(--color-border);
    transition: all 0.4s ease;
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* ===== ESTADO TRANSPARENTE (solo cuando is-transparent) ===== */
  .header.is-transparent {
    background: transparent;
    border-bottom-color: transparent;
  }

  /* Cuando hace scroll, se vuelve solido */
  .header.is-transparent.is-scrolled {
    background: var(--color-crema);
    border-bottom-color: var(--color-border);
    box-shadow: var(--shadow-md);
  }

  /* ===== LOGO ===== */
  .header-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .header-logo img {
    height: 42px;
    width: 46px;
    object-fit: contain;
  }

  /* Logo swap: por defecto mostrar dark, ocultar light */
  .logo-light { display: none; }
  .logo-dark { display: block; }

  /* Transparent (sobre hero): mostrar light, ocultar dark */
  .header.is-transparent .logo-light { display: block; }
  .header.is-transparent .logo-dark { display: none; }

  /* Scrolled (fondo solido): volver a dark */
  .header.is-transparent.is-scrolled .logo-light { display: none; }
  .header.is-transparent.is-scrolled .logo-dark { display: block; }

  .header-logo-text {
    font-size: 18px;
    font-weight: 700;
    color: var(--color-text-heading);
    letter-spacing: -0.02em;
    transition: color 0.4s ease;
  }

  /* Transparent: logo texto blanco */
  .header.is-transparent .header-logo-text {
    color: white;
  }
  .header.is-transparent.is-scrolled .header-logo-text {
    color: var(--color-text-heading);
  }

  /* ===== NAV DESKTOP ===== */
  .header-nav {
    display: flex;
    align-items: center;
    gap: 36px;
  }

  .header-link {
    text-decoration: none;
    color: var(--color-text-body);
    font-size: 15px;
    font-weight: 500;
    position: relative;
    transition: color 0.4s ease;
    white-space: nowrap;
  }

  .header-link:hover {
    color: var(--color-text-heading);
  }

  .header-link::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-orange);
    transition: width 0.3s ease;
  }

  .header-link:hover::after,
  .header-link.is-active::after {
    width: 100%;
  }

  .header-link.is-active {
    color: var(--color-text-heading);
    font-weight: 600;
  }

  /* Transparent: links blancos */
  .header.is-transparent .header-link {
    color: rgba(255, 255, 255, 0.85);
  }
  .header.is-transparent .header-link:hover {
    color: white;
  }
  .header.is-transparent.is-scrolled .header-link {
    color: var(--color-text-body);
  }
  .header.is-transparent.is-scrolled .header-link:hover,
  .header.is-transparent.is-scrolled .header-link.is-active {
    color: var(--color-text-heading);
  }

  /* ===== CTA WHATSAPP ===== */
  .header-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-whatsapp);
    color: white;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    padding: 10px 20px;
    border-radius: var(--radius-md);
    transition: all 0.4s ease;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .header-cta:hover {
    background: #20bd5a;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(37, 211, 102, 0.3);
  }

  /* Transparent (sobre hero): boton ghost */
  .header.is-transparent .header-cta {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: white;
  }
  .header.is-transparent .header-cta:hover {
    border-color: rgba(255, 255, 255, 0.4);
    background: rgba(255, 255, 255, 0.05);
    box-shadow: none;
  }

  /* Scrolled: vuelve al verde */
  .header.is-transparent.is-scrolled .header-cta {
    background: var(--color-whatsapp);
    border: none;
    color: white;
  }
  .header.is-transparent.is-scrolled .header-cta:hover {
    background: #20bd5a;
    box-shadow: 0 4px 12px rgba(37, 211, 102, 0.3);
  }

  .header-cta svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  /* ===== HAMBURGER (oculto en desktop) ===== */
  .header-hamburger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    -webkit-tap-highlight-color: transparent;
  }

  .header-hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-charcoal);
    margin: 6px 0;
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  /* Transparent: hamburger blanco */
  .header.is-transparent .header-hamburger span {
    background: white;
  }
  .header.is-transparent.is-scrolled .header-hamburger span {
    background: var(--color-charcoal);
  }

  /* Hamburger animacion X */
  .header-hamburger.is-active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 6px);
  }
  .header-hamburger.is-active span:nth-child(2) {
    opacity: 0;
  }
  .header-hamburger.is-active span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -6px);
  }

  /* ===== MENU MOBILE (oculto en desktop) ===== */
  .header-mobile {
    display: none;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .header-nav,
    .header-cta {
      display: none;
    }

    .header-hamburger {
      display: block;
    }

    .header-inner {
      height: 68px;
    }

    .header-logo img {
      height: 36px;
      width: 40px;
    }

    .header-logo-text {
      font-size: 16px;
    }

    /* Menu mobile visible */
    .header-mobile {
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 68px;
      left: 0;
      right: 0;
      bottom: 0;
      background: var(--color-crema);
      padding: 24px;
      opacity: 0;
      visibility: hidden;
      transform: translateY(-8px);
      transition: all 0.3s ease;
      pointer-events: none;
      overflow-y: auto;
    }

    .header-mobile.is-open {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
      pointer-events: auto;
    }

    .header-mobile-link {
      display: block;
      text-decoration: none;
      color: var(--color-text-heading);
      font-size: 20px;
      font-weight: 600;
      padding: 16px 0;
      border-bottom: 1px solid var(--color-border);
      transition: color 0.2s ease;
    }

    .header-mobile-link:hover,
    .header-mobile-link.is-active {
      color: var(--color-orange);
    }

    .header-mobile-cta {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      background: var(--color-whatsapp);
      color: white;
      text-decoration: none;
      font-size: 17px;
      font-weight: 600;
      padding: 16px 24px;
      border-radius: var(--radius-lg);
      margin-top: 24px;
      transition: background 0.2s ease;
    }

    .header-mobile-cta:hover {
      background: #20bd5a;
    }

    .header-mobile-cta svg {
      width: 22px;
      height: 22px;
      flex-shrink: 0;
    }
  }
</style>

<script>
  let scrollCleanup: (() => void) | null = null;
  let keydownCleanup: (() => void) | null = null;

  function initHeader() {
    // Limpiar listeners anteriores (View Transitions)
    scrollCleanup?.();
    keydownCleanup?.();

    const header = document.querySelector('[data-header]') as HTMLElement | null;
    const hamburger = document.querySelector('[data-hamburger]') as HTMLButtonElement | null;
    const mobileMenu = document.querySelector('[data-mobile-menu]') as HTMLElement | null;

    if (!header) return;

    const isTransparent = header.classList.contains('is-transparent');

    // --- Cerrar menu (reutilizable) ---
    function closeMenu() {
      mobileMenu?.classList.remove('is-open');
      hamburger?.classList.remove('is-active');
      hamburger?.setAttribute('aria-expanded', 'false');
      document.documentElement.style.overflow = '';

      if (isTransparent && window.scrollY <= 60) {
        header.classList.remove('is-scrolled');
      }
    }

    // --- Scroll: transparente → solido ---
    function onScroll() {
      if (!isTransparent) return;
      header.classList.toggle('is-scrolled', window.scrollY > 60);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // --- Hamburger toggle ---
    hamburger?.addEventListener('click', () => {
      const isOpen = mobileMenu?.classList.toggle('is-open') ?? false;
      hamburger.classList.toggle('is-active', isOpen);
      hamburger.setAttribute('aria-expanded', String(isOpen));
      document.documentElement.style.overflow = isOpen ? 'hidden' : '';

      // Forzar header solido cuando menu esta abierto
      if (isTransparent) {
        if (isOpen) {
          header.classList.add('is-scrolled');
        } else if (window.scrollY <= 60) {
          header.classList.remove('is-scrolled');
        }
      }
    });

    // --- Cerrar con Escape ---
    function onKeydown(e: KeyboardEvent) {
      if (e.key === 'Escape' && mobileMenu?.classList.contains('is-open')) {
        closeMenu();
        hamburger?.focus();
      }
    }

    document.addEventListener('keydown', onKeydown);

    // --- Focus trap en menu mobile ---
    mobileMenu?.addEventListener('keydown', (e) => {
      if (e.key !== 'Tab' || !mobileMenu.classList.contains('is-open')) return;

      const focusable = mobileMenu.querySelectorAll<HTMLElement>('a, button');
      if (!focusable.length) return;

      const first = focusable[0];
      const last = focusable[focusable.length - 1];

      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    });

    // --- Cerrar menu al hacer click en un link ---
    mobileMenu?.querySelectorAll('.header-mobile-link').forEach(link => {
      link.addEventListener('click', closeMenu);
    });

    // --- Cleanup para View Transitions ---
    scrollCleanup = () => {
      window.removeEventListener('scroll', onScroll);
    };
    keydownCleanup = () => {
      document.removeEventListener('keydown', onKeydown);
    };
  }

  // Inicializar en cada carga de pagina (View Transitions compatible)
  document.addEventListener('astro:page-load', initHeader);
</script>
